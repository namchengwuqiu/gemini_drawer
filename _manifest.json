{
  "manifest_version": 2,
  "id": "namchengwuqiu.gemini_drawer",
  "version": "1.9.15",
  "name": "Gemini 绘图",
  "description": "使用 Google Gemini API或着其他第三方平台提供的绘图服务，根据图片和提示词生成新图片。（现已支持视频生成）",
  "author": {
    "name": "sakura桜花",
    "url": "https://github.com/namchengwuqiu"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/namchengwuqiu/gemini_drawer",
    "homepage": "https://github.com/namchengwuqiu/gemini_drawer",
    "documentation": "https://github.com/namchengwuqiu/gemini_drawer#readme",
    "issues": "https://github.com/namchengwuqiu/gemini_drawer/issues"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "1.99.99"
  },
  "sdk": {
    "min_version": "2.0.0",
    "max_version": "2.99.99"
  },
  "dependencies": [
    {
      "type": "python_package",
      "name": "httpx",
      "version_spec": ">=0.26.0"
    },
    {
      "type": "python_package",
      "name": "pillow",
      "version_spec": ">=9.0.0"
    },
    {
      "type": "python_package",
      "name": "toml",
      "version_spec": ">=0.10.0"
    }
  ],
  "capabilities": [
    "send.text",
    "send.image",
    "send.video",
    "send.forward",
    "send.hybrid",
    "send.custom",
    "send.command",
    "api.call",
    "config.get",
    "llm.generate",
    "llm.get_available_models",
    "database.get",
    "message.get_by_time_in_chat",
    "message.get_by_id"
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "supported_locales": ["zh-CN"]
  },
  "plugin_type": "extension"
}
